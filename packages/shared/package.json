{
  "name": "@omni-svelte/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared utilities for omni-svelte.",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "format": "prettier --write .",
    "lint": "prettier --check . && oxlint ."
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "oxlint": "^1.51.0",
    "tsdown": "^0.21.1",
    "typescript": "^5.0.0"
  }
}
