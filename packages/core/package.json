{
    "name": "omni-svelte",
    "version": "0.0.1",
    "license": "MIT",
    "description": "Batteries included meta-framework for SvelteKit — database, auth, schema, and plugin system.",
    "keywords": [
        "svelte",
        "sveltekit",
        "omni-svelte",
        "framework",
        "orm",
        "drizzle",
        "authentication",
        "fullstack"
    ],
    "scripts": {
        "dev": "vite dev",
        "build": "vite build && pnpm run prepack",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "prepack": "svelte-kit sync && svelte-package -i ./src && publint",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "format": "prettier --write .",
        "lint": "prettier --check . && eslint .",
        "test:unit": "vitest",
        "test": "pnpm run test:unit -- --run"
    },
    "files": [
        "dist",
        "!dist/**/*.test.*",
        "!dist/**/*.spec.*"
    ],
    "sideEffects": [
        "**/*.css"
    ],
    "svelte": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "svelte": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./vite": {
            "types": "./dist/vite/index.d.ts",
            "svelte": "./dist/vite/index.js",
            "default": "./dist/vite/index.js"
        },
        "./database": {
            "types": "./dist/database/index.d.ts",
            "svelte": "./dist/database/index.js",
            "default": "./dist/database/index.js"
        },
        "./auth": {
            "types": "./dist/runtime/auth/index.d.ts",
            "svelte": "./dist/runtime/auth/index.js",
            "default": "./dist/runtime/auth/index.js"
        },
        "./validation": {
            "types": "./dist/validation/index.d.ts",
            "svelte": "./dist/validation/index.js",
            "default": "./dist/validation/index.js"
        },
        "./model": {
            "types": "./dist/database/model.d.ts",
            "svelte": "./dist/database/model.js",
            "default": "./dist/database/model.js"
        },
        "./schema": {
            "types": "./dist/schema/index.d.ts",
            "svelte": "./dist/schema/index.js",
            "default": "./dist/schema/index.js"
        },
        "./mail": {
            "types": "./dist/mail/index.d.ts",
            "svelte": "./dist/mail/index.js",
            "default": "./dist/mail/index.js"
        },
        "./queue": {
            "types": "./dist/queue/index.d.ts",
            "svelte": "./dist/queue/index.js",
            "default": "./dist/queue/index.js"
        },
        "./cache": {
            "types": "./dist/cache/index.d.ts",
            "svelte": "./dist/cache/index.js",
            "default": "./dist/cache/index.js"
        },
        "./storage": {
            "types": "./dist/storage/index.d.ts",
            "svelte": "./dist/storage/index.js",
            "default": "./dist/storage/index.js"
        },
        "./events": {
            "types": "./dist/events/index.d.ts",
            "svelte": "./dist/events/index.js",
            "default": "./dist/events/index.js"
        },
        "./notifications": {
            "types": "./dist/notifications/index.d.ts",
            "svelte": "./dist/notifications/index.js",
            "default": "./dist/notifications/index.js"
        },
        "./cli": {
            "types": "./dist/cli/index.d.ts",
            "svelte": "./dist/cli/index.js",
            "default": "./dist/cli/index.js"
        },
        "./utils": {
            "types": "./dist/utils/index.d.ts",
            "svelte": "./dist/utils/index.js",
            "default": "./dist/utils/index.js"
        }
    },
    "peerDependencies": {
        "@sveltejs/kit": "^2.27.0",
        "svelte": "^5.0.0"
    },
    "devDependencies": {
        "@eslint/compat": "^1.2.5",
        "@eslint/js": "^9.18.0",
        "@sveltejs/adapter-auto": "^6.0.0",
        "@sveltejs/kit": "^2.53.4",
        "@sveltejs/package": "^2.0.0",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@tailwindcss/forms": "^0.5.9",
        "@tailwindcss/typography": "^0.5.15",
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^20",
        "@vitest/browser": "^3.2.3",
        "drizzle-kit": "^0.31.6",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-svelte": "^3.0.0",
        "globals": "^16.0.0",
        "playwright": "^1.53.0",
        "prettier": "^3.4.2",
        "prettier-plugin-svelte": "^3.3.3",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "publint": "^0.3.2",
        "svelte": "^5.53.7",
        "svelte-check": "^4.0.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.20.0",
        "vite": "^7.0.6",
        "vite-plugin-inspect": "^11.3.0",
        "vitest": "^3.2.3",
        "vitest-browser-svelte": "^0.1.0",
        "zod": "^4.0.5"
    },
    "dependencies": {
        "@better-auth/cli": "^1.3.27",
        "@omni-svelte/shared": "workspace:*",
        "better-auth": "^1.4.4",
        "chokidar": "^4.0.3",
        "drizzle-orm": "^0.40.0",
        "glob": "^11.0.3",
        "postgres": "^3.4.5",
        "zod": "^4.0.5"
    },
    "publishConfig": {
        "access": "public"
    }
}